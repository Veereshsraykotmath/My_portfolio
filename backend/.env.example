# ── Brevo Email API configuration (HTTPS, not SMTP) ────────────
# Render's free tier blocks outbound SMTP ports, so this backend sends
# email via Brevo's HTTPS API instead. Get these from your Brevo account:
# Dashboard → SMTP & API → API Keys (BREVO_API_KEY)
# Dashboard → Senders → your verified sender email (BREVO_SENDER_EMAIL)
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=your-verified-sender@example.com

# Where contact-form submissions should be delivered
EMAIL_TO=raykotmathveeresh@gmail.com

# ── Server configuration ──────────────────────────────────────
PORT=5000
NODE_ENV=production

# Comma-separated list of origins allowed to call this API.
# Add your deployed frontend URL(s) here.
CORS_ORIGIN=https://your-portfolio-domain.com,http://localhost:5500

# ── Rate limiting ──────────────────────────────────────────────
# Max contact-form submissions allowed per IP within the time window
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=5
