# ── SMTP / Gmail configuration ────────────────────────────────
# Use a Gmail "App Password", never your real Gmail password.
# See README.md → "Gmail App Password Setup" for step-by-step instructions.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-16-character-app-password

# Where contact-form submissions should be delivered
EMAIL_TO=raykotmathveeresh@gmail.com

# ── Server configuration ──────────────────────────────────────
PORT=5000
NODE_ENV=production

# Comma-separated list of origins allowed to call this API.
# Add your deployed frontend URL(s) here.
CORS_ORIGIN=https://your-portfolio-domain.com,http://localhost:5500

# ── Rate limiting ──────────────────────────────────────────────
# Max contact-form submissions allowed per IP within the time window
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=5
